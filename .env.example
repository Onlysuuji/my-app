DATABASE_URL=postgresql://app:app@localhost:5433/my_app
AUTH_SESSION_DAYS=30
MEDIA_STORAGE_ROOT=.data/media
ACCOUNT_MAX_UPLOAD_MB=300

youtube_api_key=your_youtube_data_api_key_here
youtube_api_referer=http://localhost:3000/
YT_DLP_PATH=yt-dlp
FFMPEG_PATH=ffmpeg
YT_DLP_USER_AGENT=
# Optional yt-dlp YouTube extractor args for deploy environments.
# Example: YT_DLP_YOUTUBE_EXTRACTOR_ARGS=player_client=default,mweb
YT_DLP_YOUTUBE_EXTRACTOR_ARGS=
# Optional when Deno is installed outside PATH
# DENO_PATH=C:\Users\your-user\.deno\bin\deno.exe
YT_DLP_MAX_FILESIZE_MB=250
YT_DLP_TIMEOUT_MS=300000
YOUTUBE_IMPORT_MAX_CONCURRENT=2
# YouTube import requires cookies by default. Set 0 only for local debugging.
YT_DLP_REQUIRE_COOKIES=1

# Optional local test for the production Basic auth middleware
# APP_BASIC_AUTH_USER=admin
# APP_BASIC_AUTH_PASSWORD=replace_with_a_long_random_password

# Cookies for YouTube bot checks.
# For deploy, prefer base64 content. If both are set, YT_DLP_COOKIES_CONTENT_B64 wins.
# YT_DLP_COOKIES_CONTENT_B64=base64_encoded_cookies_txt
# Secret file path is still supported.
# YT_DLP_COOKIES_PATH=/run/secrets/youtube-cookies.txt
# Local browser fallback only works outside production.
# YT_DLP_COOKIES_FROM_BROWSER=chrome
# YT_DLP_LOCAL_BROWSER_COOKIE_FALLBACKS=edge,chrome
